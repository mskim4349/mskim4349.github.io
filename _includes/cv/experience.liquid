{% comment %}
  Compact news-style experience renderer.
  Renders each entry as a single table row: date range on the left,
  inline summary on the right. Mirrors _includes/news.liquid layout.
{% endcomment %}

<div class="news">
  <table class="table table-sm table-borderless">
    {% for entry in entries %}
      {% capture sd %}{% if entry.start_date %}{{ entry.start_date }}{% elsif entry.startDate %}{{ entry.startDate }}{% endif %}{% endcapture %}
      {% capture ed %}{% if entry.end_date %}{{ entry.end_date }}{% elsif entry.endDate %}{{ entry.endDate }}{% endif %}{% endcapture %}
      {% assign sd_label = sd | strip %}
      {% assign ed_label = ed | strip | default: 'present' %}
      {% if ed_label == 'present' or ed_label == 'Present' %}
        {% assign ed_label = 'Present' %}
      {% endif %}

      {% capture position_title %}{% if entry.position %}{{ entry.position }}{% endif %}{% endcapture %}
      {% capture company_name %}{% if entry.name %}{{ entry.name }}{% elsif entry.company %}{{ entry.company }}{% elsif entry.organization %}{{ entry.organization }}{% endif %}{% endcapture %}

      <tr>
        <th scope="row" style="width: 20%; vertical-align: top; font-weight: 600;">
          {% if sd_label != '' %}{{ sd_label }}{% if ed_label != '' %} – {{ ed_label }}{% endif %}{% endif %}
        </th>
        <td>
          <strong>{{ position_title | strip }}</strong>{% if entry.url %}, <a href="{{ entry.url }}">{{ company_name | strip }}</a>{% elsif company_name != '' %}, {{ company_name | strip }}{% endif %}.
          {% if entry.location %}
            <span class="text-muted" style="font-size: 0.9em;">({{ entry.location }})</span>
          {% endif %}
          {% if entry.summary %}
            <div style="margin-top: 0.25rem;">{{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}</div>
          {% endif %}
          {% if entry.highlights %}
            <ul style="margin: 0.25rem 0 0 0; padding-left: 1.25rem; font-size: 0.95em;">
              {% for item in entry.highlights %}
                <li>{{ item | markdownify | remove: '<p>' | remove: '</p>' }}</li>
              {% endfor %}
            </ul>
          {% endif %}
        </td>
      </tr>
    {% endfor %}
  </table>
</div>
